      "id": 100,
      "title": "Statistiques",
      "type": "row"
    },
    {
      "title": "Erreurs (ERROR) - 1h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count_over_time({service=~\"$service\"} |~ `(?i)\"level\"\\s*:\\s*\"ERROR\"|\\bERROR\\b` [$__range])",
        "legendFormat": "Errors",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Warnings (WARN) - 1h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count_over_time({service=~\"$service\"} |~ `(?i)\"level\"\\s*:\\s*\"WARN\"|\\bWARN\\b` [$__range])",
        "legendFormat": "Warnings",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 50 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Total lignes de logs - 1h",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "count_over_time({service=~\"$service\"} [$__range])",
        "legendFormat": "Total",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Volume de logs par service",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "sum by (service) (count_over_time({service=~\"$service\"}[1m]))",
        "legendFormat": "{{service}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Erreurs et Warnings",
      "type": "row"
    },
    {
      "title": "Taux d'erreurs par service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "id": 5,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ `(?i)\"level\"\\s*:\\s*\"ERROR\"|\\bERROR\\b` [1m]))",
          "legendFormat": "ERROR {{service}}",
          "refId": "A"
        },
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ `(?i)\"level\"\\s*:\\s*\"WARN\"|\\bWARN\\b` [1m]))",
          "legendFormat": "WARN {{service}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "ERROR.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "WARN.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "title": "Logs Erreurs / Warnings",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{
        "expr": "{service=~\"$service\"} |~ `(?i)\"level\"\\s*:\\s*\"(ERROR|WARN)\"|\\b(ERROR|WARN)\\b`",
        "refId": "A"
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "collapsed": false,
