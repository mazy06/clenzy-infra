    {
      "title": "Requetes HTTP / seconde",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 20,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"clenzy-backend\"}[5m])) by (method)",
        "legendFormat": "{{method}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        }
      }
    },
    {
      "title": "Latence HTTP (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"clenzy-backend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"clenzy-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"clenzy-backend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        }
      }
    },

    {
      "title": "Top 10 Endpoints (par debit)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, sum(rate(http_server_requests_seconds_count{job=\"clenzy-backend\"}[5m])) by (method, uri, status))",
        "legendFormat": "{{method}} {{uri}} [{{status}}]",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "app": true, "component": true, "exception": true, "instance": true, "outcome": true, "error": true },
            "renameByName": {
              "method": "Methode",
              "uri": "Endpoint",
              "status": "Status",
              "Value": "req/s"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "req/s", "desc": true }] }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "req/s" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 3 }
            ]
          }
        ]
      }
    },
    {
      "title": "Erreurs HTTP (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 23,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"clenzy-backend\", status=~\"4..\"}[5m]))",
          "legendFormat": "4xx (client)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"clenzy-backend\", status=~\"5..\"}[5m]))",
          "legendFormat": "5xx (server)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "4xx (client)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
