    {
      "title": "Targets UP / DOWN",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "count(up == 1)",
        "legendFormat": "UP",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Targets DOWN",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "count(up == 0) OR on() vector(0)",
        "legendFormat": "DOWN",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Statut des Targets",
      "type": "table",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "up",
        "legendFormat": "{{job}}",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "app": true },
            "renameByName": {
              "job": "Job",
              "instance": "Instance",
              "component": "Composant",
              "Value": "Statut"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Statut" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Scrape Duration (s)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "scrape_duration_seconds",
        "legendFormat": "{{job}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },

