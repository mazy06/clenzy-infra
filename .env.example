# ===========================================
# Clenzy Infrastructure - Variables d'environnement
# ===========================================
# Copier ce fichier en .env.dev (dev) ou .env (prod) et adapter les valeurs.
# IMPORTANT : Ne JAMAIS commiter les fichiers .env contenant des secrets !
#
# Usage :
#   DEV  : docker compose -f docker-compose.dev.yml --env-file .env.dev up --build
#   PROD : docker compose -f docker-compose.prod.yml --env-file .env up -d

# ---- Domaines ----
DOMAIN=clenzy.fr
APP_DOMAIN=app.clenzy.fr
AUTH_DOMAIN=auth.clenzy.fr

# ---- PostgreSQL ----
POSTGRES_DB=clenzy_prod
POSTGRES_USER=clenzy_prod_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ---- Keycloak ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_DB_PASSWORD=CHANGE_ME_keycloak_db_password
KEYCLOAK_HOSTNAME=auth.clenzy.fr
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret

# ---- Backend Spring Boot ----
JWT_SECRET=CHANGE_ME_jwt_secret_min_256_bits
SPRING_PROFILES_ACTIVE=prod

# ---- Stripe (Paiements) ----
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ---- CORS ----
ALLOWED_ORIGINS=https://app.clenzy.fr

# ---- Monitoring (Grafana) ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
MONITORING_DOMAIN=monitoring.clenzy.fr

# ---- Let's Encrypt ----
LETSENCRYPT_EMAIL=admin@clenzy.fr
# Nom du certificat dans /etc/letsencrypt/live (par défaut: DOMAIN)
CERTBOT_CERT_NAME=clenzy.fr

# ---- Landing Page ----
VITE_APP_URL=https://app.clenzy.fr

# ---- Jasypt (chiffrement tokens) ----
JASYPT_ENCRYPTOR_PASSWORD=CHANGE_ME_jasypt_password

# ---- Stripe Currency ----
STRIPE_CURRENCY=eur

# ---- Airbnb Integration (optionnel) ----
AIRBNB_CLIENT_ID=
AIRBNB_CLIENT_SECRET=
AIRBNB_REDIRECT_URI=https://app.clenzy.fr/api/airbnb/callback
AIRBNB_WEBHOOK_SECRET=

# ---- Kafka (KRaft) ----
# ID cluster KRaft (base64, 22 chars) - garder stable une fois en prod
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ---- GitHub Container Registry (CD) ----
# Token PAT pour pull les images Docker depuis ghcr.io
# Créer sur : https://github.com/settings/tokens → "read:packages"
GHCR_TOKEN=ghp_CHANGE_ME

# ---- Identifiants par defaut (NE PAS UTILISER EN PROD) ----
# PMS_DEFAULT_USER=admin@clenzy.fr
# PMS_DEFAULT_PASSWORD=CHANGE_ME
