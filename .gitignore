# Environnement (secrets)
.env
.env.*
!.env.example
prod.env
PROD_ENV_FILE_B64.txt

# SSL certificates (production)
# Les certificats auto-signés de dev sont versionnés
# En prod, remplacer par de vrais certificats (Let's Encrypt, etc.)
# nginx/ssl/*.crt
# nginx/ssl/*.key
# nginx/ssl/*.pem

# Docker volumes data
postgres-data-*/
redis-data-*/

# k6 load test results
k6/results/*.json
!k6/results/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Repos tiers clonés localement pour le dev (ex. relais WhatsApp OpenWA) — cf. docs.
# Ont leur propre .git ; à cloner à part, pas à versionner ici.
openwa/

# Artefacts de scan de sécurité (Shannon pentest) — générés, non versionnés.
app-clenzy-fr_shannon-*/

# PDFs (livrables gardés en local, hors git pour éviter le bloat binaire).
*.pdf
